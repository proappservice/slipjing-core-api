# --- local dev only; production uses GCP Secret Manager (CLAUDE.md §2) ---
DATABASE_URL="postgresql://slipjing:slipjing@localhost:5433/slipjing?schema=public"
PORT=3000

# JWT for dashboard sessions (social login only — no passwords)
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"

# Social OAuth (fill in from each provider's console)
GOOGLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# Slip2Go upstream provider (docs behind login at slip2go.com/guide)
SLIP2GO_BASE_URL="https://connect.slip2go.com/api"
SLIP2GO_API_KEY=""

# Admin console (Phase 1: single owner token; replace with real auth later)
ADMIN_TOKEN="dev-admin-token-change-me"

# Free credits granted on a user's FIRST shop (CLAUDE.md §9)
FREE_CREDITS_FIRST_SHOP=20
